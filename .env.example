# ================================================
# Torre de Control FTTH — Variables de entorno
# ================================================
# 1. Copia este archivo: cp .env.example .env
# 2. Completa los valores reales
# 3. NUNCA subas el archivo .env a GitHub

# Clave secreta para sesiones Flask (genera una aleatoria)
SECRET_KEY=cambia-esto-por-algo-aleatorio-muy-largo

# PIN de acceso para coordinadores (4-6 dígitos recomendado)
COORDINADOR_PIN=7559

# Base de datos
# SQLite local (para desarrollo):
DATABASE_URL=sqlite:///torre_control.db
# PostgreSQL en Render (para producción):
# DATABASE_URL=postgresql://usuario:password@host:5432/nombre_db

# Token para el webhook de Slack (Make.com enviará este header)
WEBHOOK_TOKEN=mi-token-secreto-para-make

# Modo debug (solo desarrollo)
FLASK_DEBUG=false
